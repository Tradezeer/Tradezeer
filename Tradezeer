local dragging = false
local dragStart
local startPos

main.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = main.Position

		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

main.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement then
		input.Changed:Connect(function()
			if dragging then
				local delta = input.Position - dragStart
				main.Position = UDim2.new(
					startPos.X.Scale,
					startPos.X.Offset + delta.X,
					startPos.Y.Scale,
					startPos.Y.Offset + delta.Y
				)
			end
		end)
	end
end)

local function clickEffect(button)
	local tween1 = TweenService:Create(button,TweenInfo.new(0.08),{
		BackgroundColor3 = Color3.fromRGB(80,140,255)
	})

	local tween2 = TweenService:Create(button,TweenInfo.new(0.08),{
		BackgroundColor3 = Color3.fromRGB(45,110,255)
	})

	tween1:Play()
	tween1.Completed:Wait()
	tween2:Play()
end

freeze.MouseButton1Click:Connect(function()
	clickEffect(freeze)
end)

auto.MouseButton1Click:Connect(function()
	clickEffect(auto)
end)

close.MouseButton1Click:Connect(function()
	gui:Destroy()
end)
